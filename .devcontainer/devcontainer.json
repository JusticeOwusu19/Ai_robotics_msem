{
  "name": "midsem",
  "dockerFile": "Dockerfile",
  "runArgs": ["--privileged", "--network=host"],
  "workspaceMount": "source=${localWorkspaceFolder},target=/home/ubuntu/ros2_ws/src/${localWorkspaceFolderBasename},type=bind",
  "workspaceFolder": "/home/ubuntu/ros2_ws/src/${localWorkspaceFolderBasename}",
  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.bash_history,target=/home/vscode/.bash_history,type=bind"
  ],
  "features": {
    "ghcr.io/devcontainers/features/desktop-lite:1": {},
    "ghcr.io/devcontainers/features/python:1": {},
    "ghcr.io/devcontainers-extra/features/ruff:2": {}
  }
}
